###############################################################################
# DecisioLens Docker/production environment
#
# Copy this file to .env before running docker compose:
#   cp .env.example .env
#   # Windows PowerShell: Copy-Item .env.example .env
###############################################################################

# Shared backend-only secret. The browser never sees this value; the Next.js
# server forwards it to FastAPI as X-API-Key.
AUDIT_API_KEY=replace-with-a-long-random-secret

# Frontend server-to-server URL used inside Docker Compose.
BACKEND_API_BASE=http://backend:8000

# Public canonical frontend URL used for metadata/social previews.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI provider. If no key is supplied, the backend uses offline fallback text.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Production runtime controls.
DEBUG=false
LOG_LEVEL=INFO
BACKEND_WEB_CONCURRENCY=2
API_DOCS_ENABLED=false

# Use explicit trusted origins in production. For a deployed frontend, replace
# localhost with your HTTPS domain, e.g. ["https://decisiolens.example.com"].
CORS_ORIGINS=["http://localhost:3000"]

# Host header allow-list for FastAPI. Add your backend/API hostname in deployed
# environments, e.g. ["api.decisiolens.example.com","backend"].
ALLOWED_HOSTS=["localhost","127.0.0.1","backend"]

# Set to 31536000 only when the API is served exclusively over HTTPS.
SECURE_HSTS_SECONDS=0

# Request/caching/AI timeout controls.
MAX_REQUEST_BODY_BYTES=131072
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=256
AI_CALL_TIMEOUT_SECONDS=10